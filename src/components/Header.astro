---
import styles from './Header.module.css';
import HeaderLink from './HeaderLink.astro';

const SITE_TITLE = 'Signal Development Operations LLC';
---

<header class={styles.mainNav} data-role="main-nav" data-expanded="false">
  <div class={`container ${styles.mainNavContainer}`}>
    <a class={styles.logo} href="/">
      <img
        src="/logo.webp"
        alt={`${SITE_TITLE} logo`}
        width="120"
        height="170"
        decoding="async"
        fetchpriority="high"
        loading="eager"
      />
      <span class={styles.logoText}>
        <strong>Signal DevOps</strong>
        <small>AI, cloud, automation, and delivery</small>
      </span>
    </a>

    <nav class={styles.links} aria-label="Primary">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/services">Services</HeaderLink>
      <HeaderLink href="/agency-partners">Agency Partners</HeaderLink>
      <HeaderLink href="/resources">Resources</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
    </nav>

    <div class={styles.actions}>
      <a class={styles.desktopCta} href="https://calendly.com/s19devops/30min">
        Schedule a Consultation
      </a>

      <button
        data-el="menu-btn"
        class={styles.menuButton}
        aria-label="Toggle menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        type="button"
      >
        <svg
          class={styles.menuIcon}
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    data-el="mobile-menu"
    class={styles.mobileMenu}
    aria-label="Mobile primary"
    data-open="false"
  >
    <div class={`container ${styles.mobileMenuInner}`}>
      <nav class={styles.mobileLinks}>
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/services">Services</HeaderLink>
        <HeaderLink href="/agency-partners">Agency Partners</HeaderLink>
        <HeaderLink href="/resources">Resources</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
        <HeaderLink href="/blog">Blog</HeaderLink>
      </nav>
      <a class={styles.mobileCta} href="https://calendly.com/s19devops/30min">
        Schedule a Consultation
      </a>
    </div>
  </div>
</header>

<script client:load>
  const header = document.querySelector('[data-role="main-nav"]');
  const btn = document.querySelector('[data-el="menu-btn"]');
  const menu = document.querySelector('[data-el="mobile-menu"]');
  const mobileLinks = menu?.querySelectorAll('a');

  const toggleMenu = () => {
    const isOpen = menu?.dataset.open === 'true';
    menu.dataset.open = (!isOpen).toString();
    header.dataset.expanded = (!isOpen).toString();
    btn.setAttribute('aria-expanded', (!isOpen).toString());
  };

  const closeMenu = () => {
    menu.dataset.open = 'false';
    header.dataset.expanded = 'false';
    btn.setAttribute('aria-expanded', 'false');
  };

  btn?.addEventListener('click', toggleMenu);
  mobileLinks?.forEach((link) => link.addEventListener('click', closeMenu));

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 960) closeMenu();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
