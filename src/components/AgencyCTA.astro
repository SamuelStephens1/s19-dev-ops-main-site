---
interface Props {
  title: string;
  subtitle: string;
  buttonLabel: string;
  href: string;
  eyebrow?: string;
  secondaryText?: string;
  external?: boolean;
}

const {
  title,
  subtitle,
  buttonLabel,
  href,
  eyebrow,
  secondaryText,
  external = false,
} = Astro.props;

const target = external ? '_blank' : undefined;
const rel = external ? 'noopener noreferrer' : undefined;
---

<section class="agency-cta">
  <div class="container agency-cta__inner">
    {eyebrow && <p class="agency-cta__eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    <p class="agency-cta__subtitle">{subtitle}</p>
    <a class="agency-cta__button" href={href} target={target} rel={rel}>
      {buttonLabel}
    </a>
    {secondaryText && <p class="agency-cta__secondary">{secondaryText}</p>}
  </div>
</section>

<style>
  .agency-cta {
    position: relative;
    overflow: hidden;
    padding: clamp(4.5rem, 8vw, 6rem) 1rem;
    background:
      linear-gradient(135deg, rgba(0, 30, 65, 0.95), rgba(10, 45, 96, 0.88)),
      url('/images/hero-bg.webp') center/cover no-repeat;
    color: #fff;
    isolation: isolate;
  }

  .agency-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      radial-gradient(circle at top right, rgba(215, 188, 35, 0.32), transparent 34%);
    background-size: 72px 72px, 72px 72px, auto;
    opacity: 0.22;
    pointer-events: none;
    z-index: -1;
  }

  .agency-cta__inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    animation: fade-rise 0.7s ease-out both;
  }

  .agency-cta__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(215, 188, 35, 0.95);
  }

  .agency-cta h2 {
    margin: 0;
    font-size: clamp(2.2rem, 5vw, 3rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .agency-cta__subtitle {
    max-width: 60ch;
    margin: 1rem auto 0;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
  }

  .agency-cta__button {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.9rem 1.8rem;
    border-radius: 9999px;
    background: #d7bc23;
    color: #001e41;
    font-size: 1rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.26);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .agency-cta__button:hover {
    background: #c0a820;
    transform: translateY(-2px);
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.3);
    text-decoration: none;
  }

  .agency-cta__secondary {
    margin: 1rem 0 0;
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  @keyframes fade-rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
