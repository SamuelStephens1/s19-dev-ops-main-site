---
const markets = [
  {
    title: 'Federal Agencies',
    description: 'Secure cloud, automation, and delivery support for defense, intel, and civilian missions.',
  },
  {
    title: 'Small and Medium Businesses',
    description: 'Enterprise discipline for teams that need scalable systems without enterprise overhead.',
  },
  {
    title: 'Enterprises',
    description: 'Platform engineering, hybrid cloud, and delivery acceleration for teams that need momentum.',
  },
  {
    title: 'Research and Universities',
    description: 'Infrastructure and data workflows ready for regulated research and grant-backed programs.',
  },
  {
    title: 'Startups',
    description: 'Modern foundations for fast-moving product teams that need to ship without rewriting later.',
  },
  {
    title: 'Nonprofits and NGOs',
    description: 'Cost-aware, resilient systems for mission-driven organizations with real compliance needs.',
  },
];
---

<section class="section-shell section-shell--light">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Markets We Serve</p>
      <h2 class="section-title">Built for teams with real stakes, real deadlines, and real constraints.</h2>
      <p class="section-copy">
        From public sector delivery to agency overflow work and startup acceleration, we build technical systems that can hold up under pressure.
      </p>
    </div>

    <div class="markets__grid">
      {markets.map((market) => (
        <article class="markets__card surface-card">
          <span class="markets__accent"></span>
          <h3>{market.title}</h3>
          <p>{market.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .markets__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .markets__card {
    padding: 1.35rem;
  }

  .markets__accent {
    display: block;
    width: 3rem;
    height: 0.25rem;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-cyan), var(--color-accent));
  }

  .markets__card h3 {
    margin: 1rem 0 0.6rem;
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .markets__card p {
    margin: 0;
    color: var(--color-ink-soft);
  }

  @media (max-width: 960px) {
    .markets__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .markets__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
