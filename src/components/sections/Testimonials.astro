---
const testimonials = [
  {
    quote: 'Signal Development Operations does amazing work. I was very impressed by their advanced skills. They went beyond my expectations in timeliness and ability.',
    source: 'Upwork Client',
  },
  {
    quote: 'Signal DevOps transformed our cloud infrastructure in weeks, not months.',
    source: 'Federal Agency Lead Engineer',
  },
  {
    quote: 'Their team built a hardened AI pipeline that passed compliance out of the box.',
    source: 'Research Institute CTO',
  },
  {
    quote: 'From planning through delivery, Signal DevOps exceeded expectations at every step.',
    source: 'Enterprise CIO',
  },
  {
    quote: 'They gave us the reliability and automation we needed to scale without extra overhead.',
    source: 'Small Business Owner',
  },
];
---

<section class="section-shell testimonials">
  <img
    src="/images/testimonials-bg.webp"
    width="1600"
    height="900"
    alt=""
    aria-hidden="true"
    fetchpriority="low"
    class="testimonials__preload"
  />

  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Client Feedback</p>
      <h2 class="section-title">Trusted by teams that needed the work done right.</h2>
      <p class="section-copy">
        We are most often brought in when the timeline is tight, the system matters, and there is no room for vague delivery.
      </p>
    </div>

    <div class="testimonials__grid">
      {testimonials.map((item, index) => (
        <article class:list={['testimonials__card', 'glass-card', { 'testimonials__card--featured': index === 0 }]}>
          <blockquote>{item.quote}</blockquote>
          <p>{item.source}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    position: relative;
    background:
      linear-gradient(135deg, rgba(4, 10, 24, 0.82), rgba(9, 19, 39, 0.7)),
      url('/images/testimonials-bg.webp') center/cover no-repeat;
  }

  .testimonials::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    opacity: 0.16;
    pointer-events: none;
  }

  .testimonials__preload {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
  }

  .testimonials__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .testimonials__card {
    padding: 1.4rem;
  }

  .testimonials__card--featured {
    grid-column: span 2;
  }

  .testimonials__card blockquote {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: #fff;
  }

  .testimonials__card p {
    margin: 1rem 0 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  @media (max-width: 960px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .testimonials__card--featured {
      grid-column: span 2;
    }
  }

  @media (max-width: 720px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonials__card--featured {
      grid-column: span 1;
    }
  }
</style>
