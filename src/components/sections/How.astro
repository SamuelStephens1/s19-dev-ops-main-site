---
const steps = [
  {
    number: '01',
    title: 'Collaborative Planning',
    description: 'We align on mission outcomes, delivery constraints, compliance needs, and the technical shape of the work.',
  },
  {
    number: '02',
    title: 'Fast Build Cycles',
    description: 'We move quickly with real implementation work, clear milestones, and systems that can be iterated in production.',
  },
  {
    number: '03',
    title: 'Transparent Delivery',
    description: 'You get direct visibility into progress, engineering decisions, and the work needed to support the system long-term.',
  },
];
---

<section class="section-shell how">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">How We Work</p>
      <h2 class="section-title">High-trust collaboration with clear momentum.</h2>
      <p class="section-copy">
        We keep the process simple: align fast, build fast, communicate clearly, and leave you with systems your team can trust.
      </p>
    </div>

    <div class="how__grid">
      {steps.map((step) => (
        <article class="how__card glass-card">
          <span class="how__number">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .how__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .how__card {
    padding: 1.5rem;
  }

  .how__number {
    display: inline-flex;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(97, 215, 255, 0.18), rgba(255, 255, 255, 0.08));
    color: #dff8ff;
    font-size: 0.95rem;
    font-weight: 800;
  }

  .how__card h3 {
    margin: 1.1rem 0 0.55rem;
    font-size: 1.3rem;
  }

  .how__card p {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 960px) {
    .how__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
