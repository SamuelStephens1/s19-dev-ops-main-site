---
const services = [
  {
    href: '/services#ai-ml',
    kicker: 'AI and ML',
    title: 'Production-ready AI systems',
    description: 'LLM integration, model delivery, MLOps, and automation workflows designed for real operations.',
  },
  {
    href: '/services#cloud',
    kicker: 'Cloud Infrastructure',
    title: 'Resilient foundations',
    description: 'Secure, scalable cloud architecture across AWS, Azure, GCP, and hybrid environments.',
  },
  {
    href: '/services#security',
    kicker: 'Cybersecurity',
    title: 'Security without drag',
    description: 'FedRAMP, CMMC, Zero Trust, and hardened delivery pipelines built into the work from day one.',
  },
  {
    href: '/services#devops',
    kicker: 'DevOps and Automation',
    title: 'Delivery that compounds',
    description: 'CI/CD, infrastructure as code, GitOps, and internal tooling that keeps teams shipping.',
  },
  {
    href: '/services#modernization',
    kicker: 'Modernization',
    title: 'Legacy to modern platforms',
    description: 'Cloud migration, system redesign, and pragmatic modernization for high-stakes environments.',
  },
  {
    href: '/services#managed',
    kicker: 'Managed Support',
    title: 'Ongoing operational coverage',
    description: 'Monitoring, support, and engineering continuity for teams that need dependable hands-on help.',
  },
];
---

<section class="section-shell services">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow">Core Services</p>
      <h2 class="section-title">Technical depth that spans strategy, build, and support.</h2>
      <p class="section-copy">
        We help teams move faster with senior engineering support across AI systems, secure cloud, DevOps, modernization, and ongoing delivery.
      </p>
    </div>

    <div class="services__grid">
      {services.map((service, index) => (
        <a class="services__card glass-card" href={service.href}>
          <span class="services__index">0{index + 1}</span>
          <p class="services__kicker">{service.kicker}</p>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
  }

  .services::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top center, rgba(97, 215, 255, 0.12), transparent 24%),
      radial-gradient(circle at bottom left, rgba(215, 188, 35, 0.12), transparent 28%);
    pointer-events: none;
  }

  .services__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .services__card {
    padding: 1.4rem;
    min-height: 18rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .services__card:hover {
    transform: translateY(-6px);
    border-color: rgba(97, 215, 255, 0.3);
  }

  .services__index {
    display: inline-flex;
    width: 2.2rem;
    height: 2.2rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(97, 215, 255, 0.12);
    color: #dff8ff;
    font-size: 0.9rem;
    font-weight: 800;
  }

  .services__kicker {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .services__card h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .services__card p:last-child {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 960px) {
    .services__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .services__grid {
      grid-template-columns: 1fr;
    }

    .services__card {
      min-height: auto;
    }
  }
</style>
