---
const today = new Date();

const COMPANY_NAME = 'Signal Development Operations, LLC';
const ADDRESS_TEXT = '335 N. Peachtree Ave, Cookeville, TN 38501';
const PHONE_DISPLAY = '(931) 536-2227';
const PHONE_TEL = '+19315362227';
const EMAIL = 's19devops@outlook.com';

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(ADDRESS_TEXT)}&output=embed`;
const directionsHref = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(ADDRESS_TEXT)}`;
---

<footer class="footer">
  <div class="container footer__wrap">
    <div class="footer__intro">
      <div class="footer__introLead">
        <p class="eyebrow footer__eyebrow">Signal DevOps</p>
        <h2>Modern infrastructure, secure delivery, and white-label build power.</h2>
      </div>
      <div class="footer__introMeta">
        <p>
          Work directly with engineers who can move from strategy to implementation without handing your project across three teams.
        </p>
        <a class="footer__introCta" href="https://calendly.com/s19devops/30min">Book a Consultation</a>
      </div>
    </div>

    <div class="footer__grid">
      <section class="footer__card footer__card--contact">
        <h3>Contact Us</h3>
        <form id="contactForm" method="POST" action="/api/contact" class="footer__form" novalidate>
          <input type="text" name="name" placeholder="Your name" required />
          <input type="email" name="email" placeholder="Work email" required />
          <textarea name="message" rows="5" placeholder="Tell us what you are building." required></textarea>
          <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="footer__hp" />
          <button type="submit" class="footer__button">Send Message</button>
          <div id="contactStatus" class="footer__status" role="status" aria-live="polite" hidden></div>
        </form>
      </section>

      <section class="footer__card">
        <h3>Reach Us</h3>
        <div class="footer__meta">
          <p><strong>{COMPANY_NAME}</strong></p>
          <p>{ADDRESS_TEXT}</p>
          <p><strong>Phone:</strong> <a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></p>
          <p><strong>Email:</strong> <a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
        </div>
        <div class="footer__hours">
          <span>Hours</span>
          <ul>
            <li>Mon-Fri: 9:00 AM - 6:00 PM</li>
            <li>Sat: By appointment</li>
            <li>Sun: Closed</li>
          </ul>
        </div>
        <a class="footer__link" href="https://www.linkedin.com/company/signal-development-operations/posts/?feedView=all" target="_blank" rel="noopener">
          Connect on LinkedIn
        </a>
      </section>

      <section class="footer__card">
        <h3>Visit</h3>
        <div class="footer__map">
          <iframe
            src={mapSrc}
            allowfullscreen
            loading="lazy"
            decoding="async"
            width="400"
            height="400"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map"
            fetchpriority="low"
          ></iframe>
        </div>
        <a class="footer__link" href={directionsHref} target="_blank" rel="noopener noreferrer">Get Directions</a>
      </section>
    </div>

    <div class="footer__bottom">
      <p>&copy; {today.getFullYear()} {COMPANY_NAME}. All rights reserved.</p>
      <p>Built for secure delivery, AI systems, cloud, and agency partnerships.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 0 0 2rem;
    background:
      linear-gradient(180deg, rgba(4, 10, 24, 0), rgba(4, 10, 24, 0.84) 18%, #040914 100%);
    color: var(--color-text);
  }

  .footer__wrap {
    position: relative;
    padding-top: 2rem;
  }

  .footer__intro {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 360px);
    gap: 2rem;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 0.5rem 0 1.25rem;
    border-bottom: 1px solid rgba(121, 154, 216, 0.14);
  }

  .footer__eyebrow {
    margin-bottom: 0.55rem;
  }

  .footer__intro h2 {
    margin: 0;
    max-width: 16ch;
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    line-height: 1.04;
    letter-spacing: -0.04em;
  }

  .footer__introMeta {
    display: grid;
    gap: 1rem;
    justify-items: start;
  }

  .footer__introMeta p {
    margin: 0;
    max-width: 34ch;
    color: rgba(220, 231, 250, 0.82);
    font-size: 0.98rem;
  }

  .footer__introCta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.78rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(97, 215, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
    color: #f6fbff;
    font-size: 0.92rem;
    font-weight: 800;
  }

  .footer__introCta:hover {
    transform: translateY(-2px);
    border-color: rgba(97, 215, 255, 0.42);
    color: var(--color-cyan);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.85fr 0.95fr;
    gap: 1.25rem;
  }

  .footer__card {
    padding: 1.5rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(121, 154, 216, 0.18);
    background: linear-gradient(180deg, rgba(15, 29, 58, 0.9), rgba(9, 19, 39, 0.9));
    box-shadow: var(--shadow-md);
  }

  .footer__card h3 {
    margin: 0 0 1rem;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }

  .footer__form {
    display: grid;
    gap: 0.8rem;
  }

  .footer__form input,
  .footer__form textarea {
    width: 100%;
    border: 1px solid rgba(121, 154, 216, 0.2);
    border-radius: 1rem;
    padding: 0.85rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }

  .footer__form input::placeholder,
  .footer__form textarea::placeholder {
    color: rgba(216, 227, 255, 0.5);
  }

  .footer__hp {
    display: none;
  }

  .footer__button {
    min-height: 3.2rem;
    border: 0;
    border-radius: 999px;
    background: linear-gradient(135deg, #f0d44f, #d7bc23);
    color: #071224;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.22);
  }

  .footer__button:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, #f4dc65, #cfb212);
  }

  .footer__button[disabled] {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .footer__status {
    padding: 0.75rem 0.9rem;
    border-radius: 1rem;
    font-size: 0.92rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(121, 154, 216, 0.18);
  }

  .footer__status.ok {
    background: rgba(24, 150, 91, 0.12);
    border-color: rgba(82, 214, 148, 0.3);
    color: #cff5df;
  }

  .footer__status.err {
    background: rgba(183, 48, 71, 0.16);
    border-color: rgba(244, 123, 143, 0.34);
    color: #ffd8de;
  }

  .footer__meta p,
  .footer__hours li,
  .footer__bottom p {
    color: rgba(220, 231, 250, 0.76);
  }

  .footer__meta a,
  .footer__link {
    color: #fff;
  }

  .footer__hours {
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(121, 154, 216, 0.14);
  }

  .footer__hours span {
    display: block;
    margin-bottom: 0.7rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .footer__hours ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .footer__map {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(121, 154, 216, 0.16);
    margin-bottom: 1rem;
  }

  .footer__map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    filter: grayscale(0.25) contrast(1.05);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
  }

  .footer__link:hover {
    color: var(--color-cyan);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(121, 154, 216, 0.14);
    font-size: 0.92rem;
  }

  @media (max-width: 1024px) {
    .footer__intro,
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__intro {
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .footer__card {
      padding: 1.2rem;
    }

    .footer__bottom {
      flex-direction: column;
    }
  }
</style>

<script is:inline>
  (() => {
    const form = document.getElementById('contactForm');
    if (!form) return;

    const statusEl = document.getElementById('contactStatus');
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      statusEl.hidden = false;
      statusEl.className = 'footer__status';
      statusEl.textContent = 'Sending...';
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const fd = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: fd,
          headers: { Accept: 'application/json' },
        });

        const raw = await res.text();
        let data = {};
        try {
          data = JSON.parse(raw);
        } catch {}

        if (res.ok && data && data.ok) {
          statusEl.classList.add('ok');
          statusEl.textContent = 'Thanks! Your message was sent.';
          form.reset();
        } else {
          statusEl.classList.add('err');
          const msg = (data && (data.error || data.message)) ? String(data.error || data.message) : `Error ${res.status}`;
          statusEl.textContent = 'Could not send: ' + msg;
        }
      } catch (err) {
        statusEl.classList.add('err');
        statusEl.textContent = 'Network error. Please try again.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  })();
</script>
